## Base de datos (Prisma)
## Comentario: esta URL se usa para desarrollo local simple (sin contenedor de base de datos).
DATABASE_URL="postgresql://USUARIO:PASSWORD@localhost:5432/NOMBRE_DB"

## PSP - Entorno
## Comentario: `sandbox` evita cobros reales; cambia a `production` solo en go-live.
PSP_ENV="sandbox"
PSP_API_BASE_URL="https://sandbox-api.tu-psp.com"

## PSP - Credenciales backend (NO exponer en frontend)
## Comentario: estas llaves se usan exclusivamente en el servidor (rutas API/backend).
PSP_API_KEY="reemplazar_api_key"
PSP_SECRET_KEY="reemplazar_secret_key"
PSP_WEBHOOK_SECRET="reemplazar_webhook_secret"
PSP_COMMERCE_CODE="reemplazar_commerce_code"

## PSP - URLs de integración
## Comentario: `PAYMENT_RETURN_URL` es navegación de usuario; `PAYMENT_WEBHOOK_PUBLIC_URL` es callback servidor a servidor.
PAYMENT_RETURN_URL="http://localhost:3000/checkout/resultado"
PAYMENT_WEBHOOK_PUBLIC_URL="https://tu-dominio.cl/api/payments/webhook"
# Application
APP_PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL (docker-compose db service)
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Prisma / app database connection
DATABASE_URL=postgresql://postgres:postgres@db:5432/ecommerce?schema=public
# Para uso local sin Docker, cambia solo el host de esta misma URL de "db" a "localhost".
# Ajusta usuario, password, host y nombre de la base segun tu entorno.
# Comentario: conserva una sola `DATABASE_URL` activa en tu `.env` final para evitar confusiones.
