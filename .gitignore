# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# Comentario: ignoramos secretos locales, pero versionamos `.env.example` como plantilla segura.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cursor
/.cursor
/.cursorrules
/ai-team 

# docs
# Se versiona la guía técnica específica de pagos PSP para Chile.
# Comentario: se ignora el resto de `doc/` para no subir borradores no controlados.
/doc/*
/doc/guia-integracion-pagos-psp-chile.md

#cursor 
/.cursor
/.cursorrules
/ai-team 
/scripts
/STACK.md
/START_HERE.md

#swc
.swc/